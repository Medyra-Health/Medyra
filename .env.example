# ─────────────────────────────────────────────────────────────────────────────
# MEDYRA — Environment Variables Template
# Copy this file to .env.local and fill in your credentials.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Connection string from MongoDB Atlas > Clusters > Connect > Drivers
MONGO_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# Name of the database (use a different DB for staging vs production)
DB_NAME=medyra

# ── Anthropic / Claude AI ─────────────────────────────────────────────────────
# https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── Clerk Authentication ───────────────────────────────────────────────────────
# https://dashboard.clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# ── Stripe Payments ────────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys  (use test keys for staging)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Obtained from Stripe Dashboard > Webhooks > Your endpoint > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Data Encryption (AES-256-GCM, GDPR Art. 32) ───────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes)
ENCRYPTION_KEY=<64-character-hex-string>

# ── Google Cloud Vision API (optional — for OCR on scanned images) ─────────────
# Base64-encoded service account JSON key
# Encode with: base64 -w 0 your-service-account.json
GOOGLE_CREDENTIALS_BASE64=<base64-encoded-json>
