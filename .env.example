# ─────────────────────────────────────────────────────────────────────────────
# MEDYRA — Environment Variables Template
# Copy this file to .env.local and fill in your credentials.
# NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Connection string from MongoDB Atlas > Clusters > Connect > Drivers
MONGO_URL=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# Name of the database (use a different DB for staging vs production)
DB_NAME=medyra

# ── AI Providers ───────────────────────────────────────────────────────────────
# Which provider serves each AI task (chat / big / vision) is set in the Admin
# Dashboard, not here — this just supplies credentials for whichever providers
# you enable there. Only the key for the provider(s) actually selected is required.

# Anthropic / Claude — https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — https://platform.openai.com/api-keys (optional, only if selected as a provider)
OPENAI_API_KEY=sk-...

# DeepSeek — https://platform.deepseek.com/api_keys (optional, only if selected as a provider)
# Note: DeepSeek's chat models don't accept image input, so it can't be used for
# the "vision" (OCR) task — the admin panel blocks that combination.
DEEPSEEK_API_KEY=sk-...

# ── Clerk Authentication ───────────────────────────────────────────────────────
# https://dashboard.clerk.com → Your App → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
# Clerk Webhook signing secret — Dashboard > Webhooks > Your endpoint > Signing Secret
# Required to verify Clerk webhook requests (prevents unauthenticated data deletion)
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

# ── Stripe Payments ────────────────────────────────────────────────────────────
# https://dashboard.stripe.com/apikeys  (use test keys for staging)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Obtained from Stripe Dashboard > Webhooks > Your endpoint > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Data Encryption (AES-256-GCM, GDPR Art. 32) ───────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes)
ENCRYPTION_KEY=<64-character-hex-string>

# ── CORS (optional override) ──────────────────────────────────────────────────
# Defaults to https://medyra.de in production; set to http://localhost:3000 for local dev
# ALLOWED_ORIGIN=http://localhost:3000

# ── Infrastructure Monitoring (Admin Dashboard) ────────────────────────────────
# All optional — each panel in the admin dashboard shows "not configured" until
# its credentials are set. Nothing else in the app depends on these.

# Vercel deployment status — https://vercel.com/account/tokens (create a token),
# project ID from Project Settings > General > Project ID
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=
# Only needed if the project lives under a Vercel team, not a personal account
# VERCEL_TEAM_ID=

# Google Search Console (SEO) — reuses GOOGLE_APPLICATION_CREDENTIALS_JSON above.
# Enable the "Google Search Console API" in the same GCP project, then add that
# service account's email as a user (Settings > Users and permissions) on the
# property in https://search.google.com/search-console
# SEARCH_CONSOLE_SITE_URL=sc-domain:medyra.de
SEARCH_CONSOLE_SITE_URL=

# MongoDB Atlas cluster health — different from MONGO_URL above. Create an API
# key pair at Atlas > Access Manager > Project Access > Create API Key (needs
# "Project Read Only" role). Project ID and cluster name are in the Atlas UI.
MONGODB_ATLAS_PUBLIC_KEY=
MONGODB_ATLAS_PRIVATE_KEY=
MONGODB_ATLAS_PROJECT_ID=
MONGODB_ATLAS_CLUSTER_NAME=
